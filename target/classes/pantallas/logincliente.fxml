<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.control.*?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Rectangle?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="besededatos.controllers.ClienteController"
           prefWidth="900.0" prefHeight="680.0"
           alignment="CENTER"
           style="-fx-background-color: #0b1e2d;">

    <!-- Decorative circles background -->
    <Circle radius="160" style="-fx-fill: rgba(26,95,138,0.15);" translateX="-300" translateY="-180"/>
    <Circle radius="120" style="-fx-fill: rgba(13,61,96,0.2);"   translateX="320"  translateY="-150"/>
    <Circle radius="100" style="-fx-fill: rgba(44,110,158,0.1);" translateX="310"  translateY="190"/>
    <Circle radius="80"  style="-fx-fill: rgba(26,95,138,0.12);" translateX="-290" translateY="190"/>

    <!-- CARD CENTRADA -->
    <VBox alignment="TOP_CENTER" spacing="0"
          maxWidth="420.0"
          StackPane.alignment="CENTER">

        <!-- HEADER -->
        <VBox alignment="CENTER" spacing="6"
              style="-fx-background-color: linear-gradient(to right, #1a5f8a, #0d3d60);
                     -fx-background-radius: 18 18 0 0;
                     -fx-padding: 28 30 22 30;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.4), 10, 0, 0, 4);">
            <HBox alignment="CENTER" spacing="10">
                <ImageView fitHeight="70" fitWidth="70" preserveRatio="true">
                    <clip>
                        <Circle centerX="35" centerY="35" radius="35" />
                    </clip>
                    <image>
                        <Image url="@../Basededatos/logo.png" />
                    </image>
                </ImageView>


                <VBox alignment="CENTER_LEFT" spacing="2">
                    <Label text="INDUSTRIA R.G"
                           style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;">
                        <font><Font name="System Bold" size="20"/></font>
                    </Label>
                    <Label text="Sistema de Gestión Integral"
                           style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.7);"/>
                </VBox>
            </HBox>
        </VBox>

        <!-- BODY -->
        <VBox spacing="0"
              style="-fx-background-color: #132636;
                     -fx-background-radius: 0 0 18 18;
                     -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 20, 0, 0, 8);
                     -fx-padding: 30 35 30 35;">

            <HBox alignment="CENTER_LEFT" spacing="8" style="-fx-padding: 0 0 20 0;">
                <Label text="🔐" style="-fx-font-size: 14px;"/>
                <Label text="Acceso al Sistema"
                       style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #7ab8d9;">
                    <font><Font name="System Bold" size="13"/></font>
                </Label>
            </HBox>

            <VBox spacing="6" style="-fx-padding: 0 0 16 0;">
                <Label text="Usuario"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7ab8d9;"/>
                <TextField fx:id="txtIdCliente"
                           promptText="Ingrese su usuario"
                           style="-fx-background-color: #1c3a52;
                                  -fx-background-radius: 10;
                                  -fx-border-color: #2a5a7a;
                                  -fx-border-radius: 10;
                                  -fx-padding: 10 14;
                                  -fx-font-size: 12px;
                                  -fx-text-fill: white;
                                  -fx-prompt-text-fill: #4a7a9b;"
                           prefWidth="350.0"/>
            </VBox>

            <VBox spacing="6" style="-fx-padding: 0 0 8 0;">
                <Label text="Contraseña"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #7ab8d9;"/>
                <PasswordField fx:id="txtTelefono"
                               promptText="Ingrese su contraseña"
                               style="-fx-background-color: #1c3a52;
                                      -fx-background-radius: 10;
                                      -fx-border-color: #2a5a7a;
                                      -fx-border-radius: 10;
                                      -fx-padding: 10 14;
                                      -fx-font-size: 12px;
                                      -fx-text-fill: white;
                                      -fx-prompt-text-fill: #4a7a9b;"
                               prefWidth="350.0"/>
            </VBox>

            <HBox alignment="CENTER_RIGHT" style="-fx-padding: 0 0 24 0;">
                <Hyperlink fx:id="linkOlvidePass"
                           text="¿Olvidaste tu contraseña?"
                           onAction="#FnOlvidoContrasena"
                           style="-fx-text-fill: #4a9cc7; -fx-font-size: 10px;
                                  -fx-border-color: transparent; -fx-underline: true;"/>
            </HBox>

            <HBox spacing="12" alignment="CENTER" style="-fx-padding: 0 0 14 0;">
                <Button text="🗑  Limpiar"
                        prefWidth="110.0" prefHeight="38.0"
                        style="-fx-background-color: #2a4a5e; -fx-background-radius: 20;
                               -fx-text-fill: #a0c4d8; -fx-font-size: 11px;
                               -fx-font-weight: bold; -fx-cursor: hand;"/>
                <Button fx:id="btnLogin"
                        defaultButton="true"
                        onAction="#FnIniciarSesion"
                        text="✔  INICIAR SESIÓN"
                        prefWidth="200.0" prefHeight="38.0"
                        style="-fx-background-color: linear-gradient(to right, #1a7abf, #0d5a8a);
                               -fx-background-radius: 20; -fx-text-fill: white;
                               -fx-font-size: 12px; -fx-font-weight: bold; -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, rgba(26,122,191,0.5), 8, 0, 0, 2);">
                    <font><Font name="System Bold" size="12"/></font>
                </Button>
            </HBox>

            <Button text="Siguiente  ▶  Entrar al Dashboard"
                    prefWidth="350.0" prefHeight="40.0"
                    style="-fx-background-color: #0d3d60; -fx-background-radius: 20;
                           -fx-text-fill: #7ab8d9; -fx-font-size: 11px; -fx-font-weight: bold;
                           -fx-cursor: hand; -fx-border-color: #1a5f8a; -fx-border-radius: 20;"/>

            <Label fx:id="lblMensaje"
                   alignment="CENTER" prefWidth="350.0" wrapText="true"
                   style="-fx-padding: 10 0 0 0; -fx-font-size: 10px;"
                   textFill="#e74c3c"/>

            <Label text="© 2025 Industria R.G  |  v2.0.1"
                   alignment="CENTER" prefWidth="350.0"
                   style="-fx-padding: 18 0 0 0; -fx-font-size: 8px; -fx-text-fill: #3a6a8a;"/>
        </VBox>
    </VBox>

</StackPane>
