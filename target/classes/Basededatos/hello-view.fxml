<HBox stylesheets="@styles.css"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="besededatos.controllers.MainController">
    <children>

        <!-- MENU LATERAL -->
        <fx:include fx:id="sideMenu" source="SideMenu.fxml" />

        <!-- CONTENIDO PRINCIPAL -->
        <VBox HBox.hgrow="ALWAYS" style="-fx-background-color: linear-gradient(to bottom, #f0f7ff, #e3f2fd);">
            <padding><Insets bottom="15" left="15" right="15" top="15" /></padding>
            <children>

                <!-- ===== TAB PANE ===== -->
                <TabPane fx:id="mainTabPane"
                         style="-fx-background-color: transparent; -fx-padding: 12 0 0 0;"
                         tabClosingPolicy="UNAVAILABLE"
                         VBox.vgrow="ALWAYS">

                    <!-- ==================== TAB 0: DASHBOARD ==================== -->
                    <Tab text="Dashboard">
                        <VBox spacing="20" style="-fx-background-color: #f8fafc;">
                            <children>
                                <!-- Header Dashboard -->
                                <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 25 10 25;">
                                    <children>
                                        <VBox spacing="5">
                                            <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0a3d62;" text="Dashboard Ejecutivo" />
                                            <Label style="-fx-text-fill: #64748b; -fx-font-size: 14px;" text="Resumen operativo y financiero de Industria R.G" />
                                        </VBox>
                                        <Region HBox.hgrow="ALWAYS" />
                                        <VBox alignment="CENTER_RIGHT" spacing="5">
                                            <Label fx:id="lblFechaActualizacion" style="-fx-text-fill: #64748b; -fx-font-size: 12px;" text="Última actualización: --" />
                                            <Button onAction="#actualizarDashboard" style="-fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 8 15; -fx-text-fill: #0a3d62; -fx-font-weight: bold;" text="Actualizar Datos" />
                                        </VBox>
                                    </children>
                                </HBox>

                                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
                                    <content>
                                        <VBox spacing="25" style="-fx-padding: 0 25 25 25;">
                                            <children>
                                                <!-- KPIs Row -->
                                                <GridPane hgap="20" vgap="20">
                                                    <columnConstraints>
                                                        <ColumnConstraints percentWidth="20" />
                                                        <ColumnConstraints percentWidth="20" />
                                                        <ColumnConstraints percentWidth="20" />
                                                        <ColumnConstraints percentWidth="20" />
                                                        <ColumnConstraints percentWidth="20" />
                                                    </columnConstraints>
                                                    <children>
                                                        <!-- KPI Card: Ventas -->
                                                        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);" GridPane.columnIndex="0">
                                                            <Label style="-fx-text-fill: #64748b; -fx-font-size: 13px;" text="Ventas Totales" />
                                                            <Label fx:id="lblVentasTotales" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0a3d62; -fx-padding: 5 0;" text="₡ 0.00" />
                                                            <Label fx:id="lblVentasTrend" style="-fx-text-fill: #10b981; -fx-font-size: 12px; -fx-font-weight: bold;" text="↑ 0.0% vs mes anterior" />
                                                        </VBox>
                                                        <!-- KPI Card: Utilidad -->
                                                        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);" GridPane.columnIndex="1">
                                                            <Label style="-fx-text-fill: #64748b; -fx-font-size: 13px;" text="Utilidad Neta" />
                                                            <Label fx:id="lblUtilidadNeta" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2563eb; -fx-padding: 5 0;" text="₡ 0.00" />
                                                            <Label style="-fx-text-fill: #64748b; -fx-font-size: 12px;" text="Margen Activo" />
                                                        </VBox>
                                                        <!-- KPI Card: Ordenes -->
                                                        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);" GridPane.columnIndex="2">
                                                            <Label style="-fx-text-fill: #64748b; -fx-font-size: 13px;" text="Órdenes Totales" />
                                                            <Label fx:id="lblOrdenesTotales" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0a3d62; -fx-padding: 5 0;" text="0" />
                                                            <Label fx:id="lblOrdenesTrend" style="-fx-text-fill: #64748b; -fx-font-size: 12px;" text="En seguimiento" />
                                                        </VBox>
                                                        <!-- KPI Card: Clientes -->
                                                        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);" GridPane.columnIndex="3">
                                                            <Label style="-fx-text-fill: #64748b; -fx-font-size: 13px;" text="Clientes Activos" />
                                                            <Label fx:id="lblClientesActivos" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #0a3d62; -fx-padding: 5 0;" text="0" />
                                                            <Label style="-fx-text-fill: #10b981; -fx-font-size: 12px; -fx-font-weight: bold;" text="Cartera Actual" />
                                                        </VBox>
                                                        <!-- KPI Card: Eficiencia -->
                                                        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4);" GridPane.columnIndex="4">
                                                            <Label style="-fx-text-fill: #64748b; -fx-font-size: 13px;" text="Eficiencia Operativa" />
                                                            <Label fx:id="lblEficiencia" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #f59e0b; -fx-padding: 5 0;" text="0%" />
                                                            <ProgressBar maxWidth="Infinity" progress="0.0" style="-fx-accent: #f59e0b;" />
                                                        </VBox>
                                                    </children>
                                                </GridPane>

                                                <!-- FILA 1: Órdenes, Finanzas, Ventas -->
                                                <HBox spacing="15">
                                                    <children>
                                                        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-padding: 15;" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0a3d62;" text="📊 Distribución de Órdenes" />
                                                                <PieChart fx:id="chartOrdenesPie" prefHeight="260" />
                                                            </children>
                                                        </VBox>
                                                        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-padding: 15;" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0a3d62;" text="💰 Ingresos vs Gastos" />
                                                                <BarChart fx:id="chartIngresosBar" prefHeight="260">
                                                                    <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                                                                    <yAxis><NumberAxis side="LEFT" /></yAxis>
                                                                </BarChart>
                                                            </children>
                                                        </VBox>
                                                        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-padding: 15;" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0a3d62;" text="📈 Evolución de Ventas" />
                                                                <LineChart fx:id="chartVentasLine" prefHeight="260">
                                                                    <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                                                                    <yAxis><NumberAxis side="LEFT" /></yAxis>
                                                                </LineChart>
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>
                                                
                                                <!-- FILA 2: Producción, Top Productos, Categorías -->
                                                <HBox spacing="15">
                                                    <children>
                                                        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-padding: 15;" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0a3d62;" text="📦 Órdenes por Mes" />
                                                                <AreaChart fx:id="chartOrdenesMesArea" prefHeight="260">
                                                                    <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                                                                    <yAxis><NumberAxis side="LEFT" /></yAxis>
                                                                </AreaChart>
                                                            </children>
                                                        </VBox>
                                                        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-padding: 15;" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0a3d62;" text="🏆 Top 5 Productos" />
                                                                <BarChart fx:id="chartTopProductosBar" prefHeight="260">
                                                                    <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                                                                    <yAxis><NumberAxis side="LEFT" /></yAxis>
                                                                </BarChart>
                                                            </children>
                                                        </VBox>
                                                        <VBox style="-fx-background-color: white; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 10, 0, 0, 4); -fx-padding: 15;" HBox.hgrow="ALWAYS">
                                                            <children>
                                                                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #0a3d62;" text="🍩 Ventas por Categoría" />
                                                                <PieChart fx:id="chartCategoriasPie" prefHeight="260" />
                                                            </children>
                                                        </VBox>
                                                    </children>
                                                </HBox>
                                            </children>
                                        </VBox>
                                    </content>
                                </ScrollPane>

                                <!-- ==================== FOOTER ==================== -->
                                <VBox style="-fx-background-color: linear-gradient(to right, #0a3d62, #1a5276); -fx-background-radius: 12 12 0 0; -fx-padding: 15 20; -fx-spacing: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 10, 0, 0, -3);">
                                    <children>

                                        <!-- Primera fila: Información principal -->
                                        <HBox alignment="CENTER_LEFT" spacing="25">
                                            <children>
                                                <!-- Logo / Nombre de la empresa -->
                                                <VBox spacing="2">
                                                    <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Arial';"
                                                           text="INDUSTRIA R.G" />
                                                    <Label style="-fx-font-size: 11px; -fx-text-fill: #aad4f0;"
                                                           text="Ventanas de Aluminio de Alta Calidad" />
                                                </VBox>

                                                <Separator orientation="VERTICAL" style="-fx-background-color: #5a7a9a; -fx-pref-width: 1;" prefHeight="40" />

                                                <!-- Versículo bíblico base -->
                                                <VBox spacing="2" HBox.hgrow="ALWAYS">
                                                    <Label style="-fx-font-size: 12px; -fx-font-style: italic; -fx-text-fill: #d4e6f1;"
                                                           text="✝️ «En todo trabajo hay ganancia, pero las simples palabras solo traen pobreza.»" />
                                                    <Label style="-fx-font-size: 11px; -fx-text-fill: #aad4f0; -fx-font-weight: bold;"
                                                           text="Proverbios 14:23 (RVR1960)" />
                                                </VBox>

                                                <Separator orientation="VERTICAL" style="-fx-background-color: #5a7a9a; -fx-pref-width: 1;" prefHeight="40" />

                                                <!-- Hora en tiempo real de RD -->
                                                <VBox spacing="2" alignment="CENTER">
                                                    <Label style="-fx-font-size: 11px; -fx-text-fill: #aad4f0;" text="🇩🇴 HORA REPÚBLICA DOMINICANA" />
                                                    <Label fx:id="lblHoraRD" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #ffd700; -fx-font-family: 'Monospaced';"
                                                           text="--:--:--" />
                                                </VBox>
                                            </children>
                                        </HBox>

                                        <!-- Segunda fila: Información de la página y créditos -->
                                        <HBox alignment="CENTER" spacing="20">
                                            <children>
                                                <Label style="-fx-font-size: 10px; -fx-text-fill: #7ab8d9;"
                                                       text="© 2026 Industria R.G - Todos los derechos reservados" />
                                                <Label style="-fx-font-size: 10px; -fx-text-fill: #5a9bc0;" text="|" />
                                                <Label style="-fx-font-size: 10px; -fx-text-fill: #7ab8d9;"
                                                       text="🖥️ Versión 3.0.0" />
                                                <Label style="-fx-font-size: 10px; -fx-text-fill: #5a9bc0;" text="|" />
                                                <Label style="-fx-font-size: 10px; -fx-text-fill: #7ab8d9;"
                                                       text="📅 Sistema creado: 28/03/2026" />
                                                <Label style="-fx-font-size: 10px; -fx-text-fill: #5a9bc0;" text="|" />
                                                <Label style="-fx-font-size: 10px; -fx-text-fill: #7ab8d9;"
                                                       text="👨‍💻 Desarrollado por: RG Solutions" />
                                            </children>
                                        </HBox>

                                        <!-- Tercera fila: Estado del sistema -->
                                        <HBox alignment="CENTER_RIGHT" spacing="10">
                                            <children>
                                                <Label style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 4 12; -fx-background-radius: 15; -fx-font-size: 10px; -fx-font-weight: bold;"
                                                       text="🟢 SISTEMA OPERATIVO" />
                                                <Label fx:id="lblUltimaConexion" style="-fx-font-size: 10px; -fx-text-fill: #7ab8d9;"
                                                       text="Última conexión: --" />
                                            </children>
                                        </HBox>

                                    </children>
                                </VBox>

                            </children>
                        </VBox>
                    </Tab>

                    <!-- ==================== TAB 1: DESGLOSE - REGISTRO ==================== -->
                    <Tab text="Registrar Desglose">
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                                    style="-fx-background-color: transparent; -fx-background: transparent;">
                            <VBox spacing="15" style="-fx-padding: 20;">
                                <children>
                                    <HBox alignment="CENTER" VBox.vgrow="ALWAYS" style="-fx-padding: 20;">
                                        <HBox style="-fx-background-color:white;-fx-background-radius:15;-fx-effect:dropshadow(gaussian,rgba(10,61,98,0.15),20,0,0,8); -fx-max-width: 900;" minHeight="500" HBox.hgrow="ALWAYS">

                                            <!-- LEFT PANEL: ILUSTRACION -->
