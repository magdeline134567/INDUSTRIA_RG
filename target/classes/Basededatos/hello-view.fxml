                                                <Label wrapText="true" style="-fx-font-size: 13px; -fx-text-fill: #aad4f0; -fx-text-alignment: CENTER;" text="Complete el formulario para registrar un nuevo desglose\n\n• Ingrese todos los datos con cuidado.\n• Verifique antes de guardar.\n• Informacion 100 segura." />
                                            </VBox>

                                            <!-- RIGHT PANEL: FORMULARIO -->
                                            <VBox style="-fx-padding: 40; -fx-spacing: 20;" HBox.hgrow="ALWAYS">
                                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #0a3d62;" text="FORMULARIO DE DESGLOSE" />
                                                <Separator style="-fx-background-color: transparent; -fx-border-color: #f0f7ff; -fx-border-width: 1 0 0 0;" />

                                                <GridPane hgap="20" vgap="12">
                                                    <columnConstraints>
                                                        <ColumnConstraints percentWidth="33" />
                                                        <ColumnConstraints percentWidth="33" />
                                                        <ColumnConstraints percentWidth="34" />
                                                    </columnConstraints>

                                                    <VBox spacing="10" GridPane.columnIndex="0">
                                                        <Label style="-fx-font-weight:bold;-fx-text-fill:#0a3d62;-fx-font-size:13px;" text="DATOS GENERALES" />
                                                        <GridPane hgap="8" vgap="8">
                                                            <columnConstraints>
                                                                <ColumnConstraints halignment="RIGHT" minWidth="75" />
                                                                <ColumnConstraints hgrow="ALWAYS" />
                                                            </columnConstraints>
                                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #0a3d62; -fx-font-size: 13px;" text="Desglose Existente:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                                            <ComboBox fx:id="cmbDesgloseExistente" maxWidth="Infinity" promptText="Seleccione desglose existente..." GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #0a3d62; -fx-font-size: 13px;" text="Filtrar por Tipo:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                                            <ComboBox fx:id="cmbCategoriaDesglose" maxWidth="Infinity" promptText="Seleccione tipo de ventana..." GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #0a3d62; -fx-font-size: 13px;" text="Cliente del Pedido:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                                            <ComboBox fx:id="cmbCliente" maxWidth="Infinity" promptText="Seleccionar cliente..." GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #0a3d62; -fx-font-size: 13px;" text="Tipo de Ventana:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                                            <ComboBox fx:id="cmbTipoVentana" maxWidth="Infinity" promptText="Seleccionar tipo..." GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #0a3d62; -fx-font-size: 13px;" text="Ancho (Metros):" GridPane.columnIndex="0" GridPane.rowIndex="4" />
                                                            <TextField fx:id="txtAncho" maxWidth="Infinity" promptText="Ej: 1.80 metros" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #0a3d62; -fx-font-size: 13px;" text="Alto (Metros):" GridPane.columnIndex="0" GridPane.rowIndex="5" />
                                                            <TextField fx:id="txtAlto" maxWidth="Infinity" promptText="Ej: 1.20 metros" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #0a3d62; -fx-font-size: 13px;" text="Área Total:" GridPane.columnIndex="0" GridPane.rowIndex="6" />
                                                            <Label fx:id="lblArea" style="-fx-font-weight:bold;-fx-text-fill:#0a3d62;" text="0.00 m2" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #0a3d62; -fx-font-size: 13px;" text="Perímetro Total:" GridPane.columnIndex="0" GridPane.rowIndex="7" />
                                                            <Label fx:id="lblPerimetro" style="-fx-font-weight:bold;-fx-text-fill:#0a3d62;" text="0.00 m" GridPane.columnIndex="1" GridPane.rowIndex="7" />
                                                        </GridPane>
                                                    </VBox>
                                                    <VBox spacing="10" GridPane.columnIndex="1">
                                                        <Label style="-fx-font-weight:bold;-fx-text-fill:#0a3d62;-fx-font-size:13px;" text="MATERIALES" />
                                                        <GridPane hgap="8" vgap="8">
                                                            <columnConstraints>
                                                                <ColumnConstraints halignment="RIGHT" minWidth="85" />
                                                                <ColumnConstraints hgrow="ALWAYS" />
                                                            </columnConstraints>
                                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #0a3d62; -fx-font-size: 13px;" text="Tipo Perfil:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                                                            <ComboBox fx:id="cmbTipoPerfil" maxWidth="Infinity" promptText="Seleccionar..." GridPane.columnIndex="1" GridPane.rowIndex="0" />
                                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #0a3d62; -fx-font-size: 13px;" text="Grosor (mm):" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                                                            <ComboBox fx:id="cmbGrosor" maxWidth="Infinity" promptText="Seleccionar..." GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #0a3d62; -fx-font-size: 13px;" text="Tipo Vidrio:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
                                                            <ComboBox fx:id="cmbTipoVidrio" maxWidth="Infinity" promptText="Seleccionar..." GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                                            <Label style="-fx-font-weight: bold; -fx-text-fill: #0a3d62; -fx-font-size: 13px;" text="Espesor (mm):" GridPane.columnIndex="0" GridPane.rowIndex="3" />
                                                            <ComboBox fx:id="cmbEspesor" maxWidth="Infinity" promptText="Seleccionar..." GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                                        </GridPane>
                                                    </VBox>
                                                    <VBox spacing="10" GridPane.columnIndex="2">
                                                        <Label style="-fx-font-weight:bold;-fx-text-fill:#0a3d62;-fx-font-size:13px;" text="COMPONENTES Y COSTOS" />
                                                        <GridPane hgap="8" vgap="8">
                                                            <columnConstraints>
                                                                <ColumnConstraints halignment="RIGHT" minWidth="85" />
                                                                <ColumnConstraints hgrow="ALWAYS" />
